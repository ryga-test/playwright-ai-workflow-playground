{
  "name": "playwright-ai-workflow-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install": "node -e \"console.log('Dependencies installed via npm install')\"",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"ESLint not configured — skipping\"",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "scripts/open-browser.sh file://$(realpath playwright-report/index.html)",
    "dashboard": "node scripts/generate-dashboard-data.js && scripts/open-browser.sh file://$(realpath index.html)"
  },
  "dependencies": {
    "@playwright/test": "latest",
    "@types/js-yaml": "latest",
    "js-yaml": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "dotenv": "latest",
    "@types/node": "latest",
    "fallow": "^2.61.0"
  }
}
